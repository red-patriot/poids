export module poids.metric;

export import poids.unit;
export import poids.unit_types;

namespace poids::metric {
  export const ::poids::Time second{1};
  export const ::poids::Mass kilogram{1};
  export const ::poids::Length meter{1};
  export const ::poids::Temperature kelvin{1};
  export const ::poids::Current ampere{1};
  export const ::poids::Amount mole{1};
  export const ::poids::Luminosity candela{1};
}  // namespace poids::metric
